{
  "name": "styleai",
  "version": "6.0.0",
  "description": "AI Fashion Assistant - Unlimited Wardrobe, Custom Sections, Online Shopping",
  "main": "main.js",
  "homepage": "./",
  "author": {
    "name": "ZEG",
    "email": "contact@zeg.com.au",
    "url": "https://zeg.com.au"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder --publish=never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.zeg.styleai",
    "productName": "StyleAI",
    "asar": true,
    "asarUnpack": [
      "assets/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "index.html",
      "app.js",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/style.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/style.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/style.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StyleAI",
      "uninstallDisplayName": "StyleAI",
      "artifactName": "StyleAI-Setup-${version}.${ext}",
      "runAfterFinish": true,
      "installerIcon": "assets/style.ico",
      "uninstallerIcon": "assets/style.ico",
      "installerHeaderIcon": "assets/style.ico",
      "menuCategory": false,
      "installerLanguages": ["en_US"],
      "displayLanguageSelector": false,
      "unicode": true,
      "warningsAsErrors": false,
      "perMachine": false,
      "allowElevation": false
    },
    "portable": {
      "artifactName": "StyleAI-Portable-${version}.${ext}",
      "requestExecutionLevel": "user"
    }
  }
}